<?php
// =================================
// 牢J公益 · API 统一入口
// 版本: v1
// 支持: GET, POST, PUT, DELETE
// =================================

// 设置响应头
header('Content-Type: application/json');
header('Access-Control-Allow-Origin: *');
header('Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS');
header('Access-Control-Allow-Headers: Content-Type, Authorization');

// 处理预检请求 (OPTIONS)
if ($_SERVER['REQUEST_METHOD'] === 'OPTIONS') {
    http_response_code(200);
    exit();
}

// 解析请求路径
$request_uri = $_SERVER['REQUEST_URI'];
$path = parse_url($request_uri, PHP_URL_PATH);
$path = str_replace('/api', '', $path);  // 去掉 /api 前缀
$segments = explode('/', trim($path, '/'));

// 版本号和实际资源
$version = $segments[0] ?? 'v1';
$resource = $segments[1] ?? '';
$id = $segments[2] ?? null;

// 获取请求方法
$method = $_SERVER['REQUEST_METHOD'];

// 获取输入数据（支持 JSON 和表单）
$input = [];
if ($method === 'GET') {
    $input = $_GET;
} else {
    $content_type = $_SERVER['CONTENT_TYPE'] ?? '';
    if (strpos($content_type, 'application/json') !== false) {
        $input = json_decode(file_get_contents('php://input'), true) ?? [];
    } else {
        $input = $_POST;
    }
}

// =================================
// 响应函数
// =================================
function json_response($code, $message, $data = null, $status = 200) {
    http_response_code($status);
    $response = [
        'code' => $code,
        'message' => $message,
        'version' => 'v1',
        'time' => date('Y-m-d H:i:s')
    ];
    if ($data !== null) {
        $response['data'] = $data;
    }
    echo json_encode($response, JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT);
    exit;
}

// 简单 API Key 验证（可选）
function check_auth() {
    $valid_key = 'laojing2026';
    $api_key = $_GET['key'] ?? $_POST['key'] ?? $_SERVER['HTTP_X_API_KEY'] ?? '';
    if ($api_key !== $valid_key) {
        json_response(403, '无效的API密钥', null, 403);
    }
}

// =================================
// 路由分发
// =================================

// 只处理 v1 版本
if ($version !== 'v1') {
    json_response(404, '不支持的API版本', null, 404);
}

// 根据资源路由
switch ($resource) {
// ========== 谁是卧底 ==========
case 'undercover':
    $action = $_GET['action'] ?? 'start';
    session_start();
    
    // 词语库
    $word_pairs = [
        ['civil' => '苹果', 'undercover' => '香蕉'],
        ['civil' => '可乐', 'undercover' => '雪碧'],
        ['civil' => '猫', 'undercover' => '狗'],
        ['civil' => '电脑', 'undercover' => '手机'],
        ['civil' => '足球', 'undercover' => '篮球'],
        ['civil' => '咖啡', 'undercover' => '茶'],
        ['civil' => '火车', 'undercover' => '高铁'],
        ['civil' => '老师', 'undercover' => '学生'],
        ['civil' => '医生', 'undercover' => '护士'],
        ['civil' => '夏天', 'undercover' => '冬天'],
    ];
    
    // 开始游戏
    if ($action == 'start') {
        $pair = $word_pairs[array_rand($word_pairs)];
        $is_undercover = rand(0, 1) == 1;
        
        $_SESSION['undercover_game'] = [
            'civil' => $pair['civil'],
            'undercover' => $pair['undercover'],
            'is_undercover' => $is_undercover,
            'word' => $is_undercover ? $pair['undercover'] : $pair['civil'],
            'start_time' => time()
        ];
        
        json_response(200, '游戏开始', [
            'word' => $_SESSION['undercover_game']['word'],
            'role' => $is_undercover ? '卧底' : '平民',
            'total_players' => '多人游戏请自行组织'
        ]);
        break;
    }
    
    // 揭晓答案
    if ($action == 'reveal') {
        if (!isset($_SESSION['undercover_game'])) {
            json_response(400, '请先开始游戏');
        }
        json_response(200, '游戏结束', [
            'civil_word' => $_SESSION['undercover_game']['civil'],
            'undercover_word' => $_SESSION['undercover_game']['undercover'],
            'result' => '卧底词是：' . $_SESSION['undercover_game']['undercover']
        ]);
        break;
    }
    
    json_response(400, '无效操作，支持 action: start, reveal');
    break;
// ========== 文字转语音 ==========
case 'tts':
    $text = $_GET['text'] ?? '';
    if (empty($text)) {
        json_response(400, '缺少 text 参数');
    }
    
    // 你的百度 API 配置
    $api_key = 'dXpbJheOuj4MeSURICG7PuK5';
$secret_key = 'jCTW1iF5BJfRgKERN4GpgqkCbDgxBe69';
    
    // 获取 access_token
    $token_url = "https://aip.baidubce.com/oauth/2.0/token?grant_type=client_credentials&client_id={$api_key}&client_secret={$secret_key}";
    $token_res = file_get_contents($token_url);
    $token_data = json_decode($token_res, true);
    
    if (!isset($token_data['access_token'])) {
        json_response(500, '获取 token 失败: ' . ($token_data['error_description'] ?? '未知错误'));
    }
    $token = $token_data['access_token'];
    
    // 合成语音参数
    $params = [
        'tex' => $text,
        'tok' => $token,
        'cuid' => 'laojing_public',
        'ctp' => 1,
        'lan' => 'zh',
        'per' => 0,      // 发音人：0-女声，1-男声，3-情感合成
        'spd' => 5,      // 语速 0-9
        'pit' => 5,      // 音调 0-9
        'vol' => 9,      // 音量 0-15
        'aue' => 3       // 3-mp3，6-pcm
    ];
    
    $voice_url = "https://tsn.baidu.com/text2audio?" . http_build_query($params);
    
    // 获取音频
    $audio = file_get_contents($voice_url);
    
    // 检查是否返回错误
    if (strpos($audio, 'error') !== false) {
        json_response(500, '语音合成失败: ' . $audio);
    }
    
    // 返回音频流
    header('Content-Type: audio/mp3');
    header('Content-Disposition: inline; filename="tts.mp3"');
    header('Content-Length: ' . strlen($audio));
    echo $audio;
    exit;
    break;
// ========== 本地二维码生成接口（不依赖外部API）==========
    // ========== 自助建站接口 ==========
    case 'createpage':
        check_auth();
        
        $baseDir = '/opt/data/user_pages/';
        $maxFolders = 10;
        
        if ($method === 'GET') {
            $pages = [];
            if (is_dir($baseDir)) {
                foreach (glob($baseDir . '*', GLOB_ONLYDIR) as $folderPath) {
                    $folder = basename($folderPath);
                    foreach (glob($folderPath . '/*.{html,htm}', GLOB_BRACE) as $filePath) {
                        $filename = basename($filePath);
                        if ($filename === 'index.html' || $filename === 'index.htm') {
                            $url = "https://e.ljgy123.top/{$folder}/'";
                        } else {
                            $url = "https://e.ljgy123.top/{$folder}/{$filename}'";
                        }
                        $pages[] = ['folder' => $folder, 'file' => $filename, 'url' => $url];
                    }
                }
            }
            json_response(200, '获取页面列表成功', ['pages' => $pages]);
            
        } elseif ($method === 'POST') {
            $folder = trim($input['folder'] ?? '');
            $filename = trim($input['filename'] ?? '');
            $code = $input['code'] ?? '';
            
            if (!preg_match('/^[a-zA-Z0-9_-]+$/', $folder)) {
                json_response(400, '文件夹名只能包含字母、数字、下划线、短横线', null, 400);
            }
            
            if (!preg_match('/^[a-zA-Z0-9_.-]+$/', $filename)) {
                json_response(400, '文件名只能包含字母、数字、下划线、短横线、点', null, 400);
            }
            
            if (preg_match('/.php$/i', $filename)) {
                json_response(400, '禁止创建 PHP 文件', null, 400);
            }
            
            if (!is_dir($baseDir)) {
                mkdir($baseDir, 0755, true);
            }
            
            $existingFolders = glob($baseDir . '*', GLOB_ONLYDIR);
            if (count($existingFolders) >= $maxFolders && !is_dir($baseDir . $folder)) {
                json_response(400, "最多只能创建 {$maxFolders} 个文件夹'", null, 400);
            }
            
            $targetDir = $baseDir . $folder;
            if (!is_dir($targetDir)) {
                mkdir($targetDir, 0755, true);
            }
            
            $filePath = $targetDir . '/' . $filename;
            $code = preg_replace('/<?php/i', '&lt;?php', $code);
            $code = preg_replace('/<?=/i', '&lt;?=', $code);
            
            if (file_put_contents($filePath, $code)) {
                if ($filename === 'index.html' || $filename === 'index.htm') {
                    $url = "https://e.ljgy123.top/{$folder}/'";
                } else {
                    $url = "https://e.ljgy123.top/{$folder}/{$filename}'";
                }
                json_response(200, '创建成功', ['url' => $url]);
            } else {
                json_response(500, '写入失败，请检查目录权限', null, 500);
            }
            
        } else {
            json_response(405, '方法不允许', null, 405);
        }
        break;

case 'qrlocal':
    // 获取参数
    $text = $input['text'] ?? '';
    $size = $input['size'] ?? 6;        // 二维码大小 (1-10)
    $margin = $input['margin'] ?? 2;     // 边距
    $level = $input['level'] ?? 'L';      // 纠错级别 L/M/Q/H
    
    if (empty($text)) {
        json_response(400, '缺少text参数', null, 400);
    }
    
    // 限制长度防止滥用
    if (strlen($text) > 1000) {
        json_response(400, 'text太长，最多1000字符', null, 400);
    }
    
    // 引入phpqrcode库
    require_once('/opt/phpqrcode/qrlib.php');
    
    // 设置纠错级别
    $errorCorrection = QR_ECLEVEL_L;
    if ($level == 'M') $errorCorrection = QR_ECLEVEL_M;
    if ($level == 'Q') $errorCorrection = QR_ECLEVEL_Q;
    if ($level == 'H') $errorCorrection = QR_ECLEVEL_H;
    
    // 生成到临时文件
    $tempDir = '/tmp/';
    $fileName = md5($text . $size . $margin . $level) . '.png';
    $pngAbsoluteFilePath = $tempDir . $fileName;
    
    // 生成二维码
    QRcode::png($text, $pngAbsoluteFilePath, $errorCorrection, $size, $margin);
    
    // 如果请求的是直接返回图片
    if (isset($input['raw']) && $input['raw'] === 'true') {
        header('Content-Type: image/png');
        header('Content-Disposition: inline; filename="qrcode.png"');
        readfile($pngAbsoluteFilePath);
        unlink($pngAbsoluteFilePath);
        exit;
    }
    
    // 否则返回图片的base64或URL
    if (isset($input['base64']) && $input['base64'] === 'true') {
        $imageData = base64_encode(file_get_contents($pngAbsoluteFilePath));
        $data = [
            'text' => $text,
            'base64' => 'data:image/png;base64,' . $imageData,
            'size' => $size,
            'level' => $level
        ];
        unlink($pngAbsoluteFilePath);
        json_response(200, '二维码生成成功', $data);
    } else {
        // 返回一个访问链接（需要配合Nginx访问临时文件）
        $qr_url = 'http://api.ljgy123.top/tmp/qr/' . $fileName;
        $data = [
            'text' => $text,
            'qr_url' => $qr_url,
            'size' => $size,
            'level' => $level,
            'note' => '直接访问此URL即可获得二维码图片（临时文件，1小时后删除）'
        ];
        json_response(200, '二维码生成成功', $data);
    }
    break;
// ========== IP 接口（获取访问者IP）==========
case 'ip':
    // 获取真实IP（考虑代理）
    function getClientIP() {
        $ip = '';
        
        // 1. 如果有 Cloudflare，从 CF 头部获取
        if (!empty($_SERVER['HTTP_CF_CONNECTING_IP'])) {
            $ip = $_SERVER['HTTP_CF_CONNECTING_IP'];
        }
        // 2. 从 X-Forwarded-For 获取（有代理时）
        elseif (!empty($_SERVER['HTTP_X_FORWARDED_FOR'])) {
            $ips = explode(',', $_SERVER['HTTP_X_FORWARDED_FOR']);
            $ip = trim($ips[0]);
        }
        // 3. 从 X-Real-IP 获取（Nginx 代理）
        elseif (!empty($_SERVER['HTTP_X_REAL_IP'])) {
            $ip = $_SERVER['HTTP_X_REAL_IP'];
        }
        // 4. 直接获取远程地址
        elseif (!empty($_SERVER['REMOTE_ADDR'])) {
            $ip = $_SERVER['REMOTE_ADDR'];
        }
        
        return $ip ?: 'unknown';
    }
    
    // 获取更多IP信息（可选）
    $client_ip = getClientIP();
    $user_agent = $_SERVER['HTTP_USER_AGENT'] ?? 'unknown';
    
    // 判断是否本地访问
    $is_local = in_array($client_ip, ['127.0.0.1', '::1', 'localhost']);
    
    $data = [
        'your_ip' => $client_ip,
        'is_local' => $is_local,
        'user_agent' => $user_agent,
        'timestamp' => time(),
        'note' => '这是你的公网或内网IP，取决于你如何访问'
    ];
    
    // 可以加个参数控制返回格式
    if (isset($input['simple']) && $input['simple'] === 'true') {
        echo $client_ip;
        exit;
    }
    
    json_response(200, '获取访问者IP成功', $data);
    break;
// ========== 时间接口 ==========
case 'time':
    // 获取请求参数
    $format = $input['format'] ?? 'iso';  // 格式：iso, timestamp, date
    $timezone = $input['tz'] ?? 'Asia/Shanghai';
    
    // 设置时区
    date_default_timezone_set($timezone);
    
    $now = time();
    $data = [
        'timestamp' => $now,
        'iso' => date('c', $now),
        'date' => date('Y-m-d', $now),
        'time' => date('H:i:s', $now),
        'datetime' => date('Y-m-d H:i:s', $now),
        'timezone' => $timezone,
        'weekday' => date('l', $now),
        'week' => date('W', $now),
        'day_of_year' => date('z', $now) + 1
    ];
    
    // 如果指定了格式，只返回对应字段
    if ($format !== 'all' && isset($data[$format])) {
        json_response(200, '时间获取成功', [$format => $data[$format]]);
    } else {
        json_response(200, '时间获取成功', $data);
    }
    break;
    // ========== 测试接口 ==========
    case 'test':
        json_response(200, 'API测试成功', [
            'method' => $method,
            'id' => $id,
            'input' => $input
        ]);
        break;
    
    // ========== 帖子接口 ==========
    case 'posts':
        // 需要验证
        check_auth();
        
        // 根据请求方法和 ID 分发
        if ($method === 'GET' && !$id) {
            // GET /posts - 获取帖子列表
            $limit = $input['limit'] ?? 10;
            // 这里连数据库查询
            json_response(200, '获取帖子列表', [
                'limit' => $limit,
                'posts' => [
                    ['id' => 1, 'title' => '帖子1'],
                    ['id' => 2, 'title' => '帖子2']
                ]
            ]);
            
        } elseif ($method === 'GET' && $id) {
            // GET /posts/1 - 获取单个帖子
            json_response(200, '获取帖子详情', [
                'id' => $id,
                'title' => '帖子标题',
                'content' => '帖子内容'
            ]);
            
        } elseif ($method === 'POST' && !$id) {
            // POST /posts - 创建新帖子
            $title = $input['title'] ?? '';
            $content = $input['content'] ?? '';
            if (!$title || !$content) {
                json_response(400, '缺少标题或内容', null, 400);
            }
            // 插入数据库...
            json_response(201, '帖子创建成功', [
                'id' => rand(100, 999),
                'title' => $title
            ], 201);
            
        } elseif ($method === 'PUT' && $id) {
            // PUT /posts/1 - 更新帖子
            json_response(200, '帖子更新成功', [
                'id' => $id,
                'updated' => true
            ]);
            
        } elseif ($method === 'DELETE' && $id) {
            // DELETE /posts/1 - 删除帖子
            json_response(200, '帖子删除成功', [
                'id' => $id,
                'deleted' => true
            ]);
            
        } else {
            json_response(405, '方法不允许', null, 405);
        }
        break;
    
    // ========== 用户接口 ==========
    case 'users':
        check_auth();
        // 类似 posts 的逻辑...
        json_response(200, '用户接口', [
            'method' => $method,
            'id' => $id
        ]);
        break;
    
    // ========== 默认 404 ==========
    default:
        json_response(404, '接口不存在', null, 404);
}
