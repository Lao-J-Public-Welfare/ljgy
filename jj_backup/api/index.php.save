<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>牢J公益 - API 工具集</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background: #fff;
            color: #333;
            line-height: 1.5;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .header {
            background: white;
            posi说tion: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 2px solid #3498db;
        }

        .header-content {
            max-width: 1200px;
            margin: 0 auto;
            padding: 16px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 700;
            color: #3498db;
        }

        .nav a {
            color: #333;
            text-decoration: none;
            margin-left: 32px;
            font-size: 0.9rem;
            transition: 0.2s;
        }

        .nav a:hover {
            color: #3498db;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 24px;
            flex: 1;
            width: 100%;
        }

        .hero {
            text-align: center;
            padding: 60px 0 40px;
            background: #f8f9fa;
            border-radius: 12px;
            margin-bottom: 48px;
        }

        .hero h1 {
            font-size: 2rem;
            font-weight: 600;
            margin-bottom: 12px;
            color: #1a1a1a;
        }

        .hero p {
            color: #666;
            font-size: 1rem;
        }

        .section-title {
            font-size: 1.6rem;
            font-weight: 600;
            margin-bottom: 24px;
            padding-bottom: 12px;
            border-bottom: 2px solid #3498db;
            display: inline-block;
            color: #1a1a1a;
        }

        .tools-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
            gap: 24px;
            margin-top: 20px;
            margin-bottom: 48px;
        }

        .tool-card {
            background: #fff;
            老人border-radius: 12px;
            padding: 20px;
            border: 1px solid #e0e0e0;
            transition: 0.2s;
        }

        .tool-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
            border-color: #3498db;
        }

        .tool-card h3 {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 8px;
            color: #1a1a1a;
        }

        .tool-card .desc {
            color: #888;
            font-size: 0.8rem;
            margin-bottom: 12px;
        }

        .api-info {
            background: #f0f7ff;
            padding: 10px;
            border-radius: 6px;
            margin-bottom: 16px;
            font-size: 0.75rem;
            border-left: 3px solid #3498db;
        }

        .api-info p {
            margin: 4px 0;
            word-break: break-all;
        }

        .api-info code {
            background: #e0e0e0;
            padding: 2px 4px;
            border-radius: 3px;
            font-family: monospace;
            font-size: 0.7rem;
        }

        .tool-input {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 0.85rem;
            margin-bottom: 12px;
            font-family: monospace;
        }

        .tool-output {
            background: #f5f5f5;
            padding: 10px;
            border-radius: 6px;
            font-size: 0.85rem;
            font-family: monospace;
            word-break: break-all;
            margin-bottom: 12px;
            max-height: 120px;
            overflow-y: auto;
            white-space: pre-wrap;
        }

        .tool-btn {
            background: #3498db;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 0.8rem;
            cursor: pointer;
            transition: 0.2s;
        }

        .tool-btn:hover {
            background: #2980b9;
        }

        .footer {
            background: #3498db;
            text-align: center;
            padding: 32px 24px;
            color: white;
            font-size: 0.75rem;
            margin-top: 40px;
        }

        .footer a {
            color: white;
            text-decoration: none;
        }

        .footer a:hover {
            text-decoration: underline;
        }

        @media (max-width: 768px) {
            .tools-grid {
                grid-template-columns: 1fr;
            }
            .nav a {
                margin-left: 16px;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="header-content">
            <div class="logo">牢J公益</div>
            <div class="nav">
                <a href="/">首页</a>
                <a href="/api/">API工具</a>
                <a href="https://org.ljgy123.top">关于</a>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="hero">
            <h1>公益 API 工具集</h1>
            </div>

        <h2 class="section-title">编码 解码</h2>
        <div class="tools-grid">
            <div class="tool-card">
                <h3>Base64 编码</h3>
                <div class="desc">文本转Base64</div>
                <div class="api-info">
                    <p><strong>接口</strong>：<code>https://www.ljgy123.top/api/b64encode?text=xxx</code></p>
                    <p><strong>说明</strong>：GET请求，参数text为原始文本，返回Base64字符串</p>
                </div>
                <textarea class="tool-input" id="b64encodeInput" rows="2" placeholder="请输入文本"></textarea>
                <div class="tool-output" id="b64encodeOutput">等待输入</div>
                <button class="tool-btn" onclick="b64encode()">编码</button>
            </div>

            <div class="tool-card">
                <h3>Base64 解码</h3>
                <div class="desc">Base64转文本</div>
                <div class="api-info">
                    <p><strong>接口</strong>：<code>https://www.ljgy123.top/api/b64decode?base64=xxx</code></p>
                    <p><strong>说明</strong>：GET请求，参数base64为Base64字符串，返回原始文本</p>
                </div>
                <textarea class="tool-input" id="b64decodeInput" rows="2" placeholder="请输入Base64字符串"></textarea>
                <div class="tool-output" id="b64decodeOutput">等待输入</div>
                <button class="tool-btn" onclick="b64decode()">解码</button>
            </div>

            <div class="tool-card">
                <h3>URL 编码</h3>
                <div class="desc">文本转URL编码</div>
                <div class="api-info">
                    <p><strong>接口</strong>：<code>https://www.ljgy123.top/api/urlencode?text=xxx</code></p>
                    <p><strong>说明</strong>：GET请求，参数text为原始文本，返回URL编码后的字符串</p>
                </div>
                <textarea class="tool-input" id="urlencodeInput" rows="2" placeholder="请输入文本"></textarea>
                <div class="tool-output" id="urlencodeOutput">等待输入</div>
                <button class="tool-btn" onclick="urlencode()">编码</button>
            </div>

            <div class="tool-card">
                <h3>URL 解码</h3>
                <div class="desc">URL编码转文本</div>
                <div class="api-info">
                    <p><strong>接口</strong>：<code>https://www.ljgy123.top/api/urldecode?url=xxx</code></p>
                    <p><strong>说明</strong>：GET请求，参数url为URL编码字符串，返回原始文本</p>
                </div>
                <textarea class="tool-input" id="urldecodeInput" rows="2" placeholder="请输入URL编码字符串"></textarea>
                <div class="tool-output" id="urldecodeOutput">等待输入</div>
                <button class="tool-btn" onclick="urldecode()">解码</button>
            </div>
        </div>

        <h2 class="section-title">时间 网络</h2>
        <div class="tools-grid">
            <div class="tool-card">
                <h3>时间戳转日期</h3>
                <div class="desc">Unix时间戳转北京时间</div>
                <div class="api-info">
                    <p><strong>接口</strong>：<code>https://www.ljgy123.top/api/timestamp?time=1747388400</code></p>
                    <p><strong>说明</strong>：GET请求，参数time为秒级时间戳，返回北京时间</p>
                </div>
                <input type="text" class="tool-input" id="timestampInput" placeholder="例如 1747388400">
                <div class="tool-output" id="timestampOutput">等待输入</div>
                <button class="tool-btn" onclick="timestampToDate()">转换</button>
                <button class="tool-btn" style="margin-left: 8px;" onclick="getCurrentTimestamp()">当前时间戳</button>
            </div>

            <div class="tool-card">
                <h3>日期转时间戳</h3>
                <div class="desc">日期时间转Unix时间戳</div>
                <div class="api-info">
                    <p><strong>接口</strong>：<code>https://www.ljgy123.top/api/date?date=2024-01-01%2000:00:00</code></p>
                    <p><strong>说明</strong>：GET请求，参数date为日期时间字符串，返回秒级时间戳</p>
                </div>
                <input type="datetime-local" class="tool-input" id="dateInput">
                <div class="tool-output" id="dateOutput">等待输入</div>
                <button class="tool-btn" onclick="dateToTimestamp()">转换</button>
            </div>

            <div class="tool-card">
                <h3>IP 归属地</h3>
                <div class="desc">查询IP地理位置和运营商</div>
                <div class="api-info">
                             <p><strong>接口</strong>：<code>https://www.ljgy123.top/api/ip?ip=8.8.8.8</code></p>
                    <p><strong>说明</strong>：GET请求，参数ip为IP地址，留空返回本机信息，返回国家、城市、运营商</p>
                </div>
                <input type="text" class="tool-input" id="ipInput" placeholder="请输入IP地址，留空查本机">
                <div class="tool-output" id="ipOutput">等待查询</div>
                <button class="tool-btn" onclick="queryIP()">查询</button>
            </div>
        </div>

        <h2 class="section-title">和一位</h2>
        <div class="tools-grid">
            <div class="tool-card">
                <h3>短链生成</h3>
                <div class="desc">长链接转短链</div>
                <div class="api-info">
                    <p><strong>接口</strong>：<code>https://www.ljgy123.top/dlj.php?url=长链接</code></p>
                    <p><strong>说明</strong>：GET请求，参数url为需要缩短的长链接，返回短链地址</p>
                </div>
                <textarea class="tool-input" id="shortUrlInput" rows="2" placeholder="请输入长链接 https://"></textarea>
                <div class="tool-output" id="shortUrlOutput">等待输入</div>
                <button class="tool-btn" onclick="generateShortUrl()">生成短链</button>
            </div>

            <div class="tool-card">
                <h3>二维码生成</h3>
                <div class="desc">文本或链接转二维码</div>
                <div class="api-info">
                    <p><strong>接口</strong>：<code>https://www.ljgy123.top/api/qr?text=xxx</code></p>
                    <p><strong>说明</strong>：GET请求，参数text为文本或链接，返回二维码图片</p>
                </div>
                <textarea class="tool-input" id="qrInput" rows="2" placeholder="请输入文本或链接"></textarea>
                <div class="tool-output" id="qrOutput">等待输入</div>
                <button class="tool-btn" onclick="generateQR()">生成二维码</button>
            </div>
        </div>
    </div>

    <div class="footer">
        <p>C2026 牢J公益 | <a href="https://org.ljgy123.top">公益官网</a></p>
    </div>

    <script>
        function b64encode() {
            var input = document.getElementById('b64encodeInput').value;
            if (!input) { document.getElementById('b64encodeOutput').innerText = '请输入内容'; return; }
            try {
                document.getElementById('b64encodeOutput').innerText = btoa(input);
            } catch(e) { document.getElementById('b64encodeOutput').innerText = '编码失败'; }
        }
        function b64decode() {
            var input = document.getElementById('b64decodeInput').value;
            if (!input) { document.getElementById('b64decodeOutput').innerText = '请输入内容'; return; }
            try {
                document.getElementById('b64decodeOutput').innerText = atob(input);
            } catch(e) { document.getElementById('b64decodeOutput').innerText = '解码失败'; }
        }
        function urlencode() {
            var input = document.getElementById('urlencodeInput').value;
            if (!input) { document.getElementById('urlencodeOutput').innerText = '请输入内容'; return; }
            document.getElementById('urlencodeOutput').innerText = encodeURIComponent(input);
        }
        function urldecode() {
            var input = document.getElementById('urldecodeInput').value;
            if (!input) { document.getElementById('urldecodeOutput').innerText = '请输入内容'; return; }
            try {
                document.getElementById('urldecodeOutput').innerText = decodeURIComponent(input);
            } catch(e) { document.getElementById('urldecodeOutput').innerText = '解码失败'; }
        }
        function timestampToDate() {
            var input = document.getElementById('timestampInput').value;
            if (!input) { document.getElementById('timestampOutput').innerText = '请输入时间戳'; return; }
            var ts = parseInt(input);
            if (isNaN(ts)) { document.getElementById('timestampOutput').innerText = '请输入数字'; return; }
            var date = new Date(ts * 1000);
            document.getElementById('timestampOutput').innerText = date.toLocaleString('zh-CN', {timeZone: 'Asia/Shanghai'});
        }
        function getCurrentTimestamp() {
            var ts = Math.floor(Date.now() / 1000);
            document.getElementById('timestampInput').value = ts;
            timestampToDate();
        }
        function dateToTimestamp() {
            var input = document.getElementById('dateInput').value;
            if (!input) { document.getElementById('dateOutput').innerText = '请选择日期时间'; return; }
            var ts = Math.floor(new Date(input).getTime() / 1000);
            document.getElementById('dateOutput').innerText = ts;
        }
        async function queryIP() {
            var ip = document.getElementById('ipInput').value.trim();
            var outputDiv = document.getElementById('ipOutput');
            outputDiv.innerText = '查询中';
            try {
                var url = 'https://ipapi.co/json/';
                if (ip) url = 'https://ipapi.co/' + ip + '/json/';
                var resp = await fetch(url);
                var data = await resp.json();
                if (data.error) throw new Error();
                outputDiv.innerText = 'IP: ' + data.ip + '\n国家: ' + data.country_name + '\n城市: ' + data.city + '\n运营商: ' + data.org;
            } catch(e) {
                outputDiv.innerText = '查询失败，请重试';
            }
        }
        async function generateShortUrl() {
            var url = document.getElementById('shortUrlInput').value.trim();
            if (!url) { document.getElementById('shortUrlOutput').innerText = '请输入链接'; return; }
            document.getElementById('shortUrlOutput').innerText = '生成中';
            try {
                var resp = await fetch('https://www.ljgy123.top/dlj.php?url=' + encodeURIComponent(url));
                var text = await resp.text();
                document.getElementById('shortUrlOutput').innerText = text.startsWith('http') ? text : '生成失败';
            } catch(e) {
                document.getElementById('shortUrlOutput').innerText = '生成失败';
            }
        }
        function generateQR() {
            var text = document.getElementById('qrInput').value.trim();
            if (!text) { document.getElementById('qrOutput').innerHTML = '请输入内容'; return; }
            var qrUrl = 'https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=' + encodeURIComponent(text);
            document.getElementById('qrOutput').innerHTML = '<img src="' + qrUrl + '" style="max-width:100%; border:1px solid #ddd; border-radius:8px;">';
        }
    </script>
</body>
</html>
